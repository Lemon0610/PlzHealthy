<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="건강점수 일지"
            android:textColor="@color/GoodBlack"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHealthLogDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="2026년 05월 03일"
            android:textColor="@color/LightBlack"
            android:textSize="14sp" />

        <!-- 오늘의 건강점수 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 건강점수"
                android:textColor="@color/LightBlack"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvAverageHealthScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0점"
                android:textColor="@color/MainGreen"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="오늘의 건강점수 요약이 표시됩니다."
                android:textColor="@color/GoodBlack"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- 건강점수 변화 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="건강점수 변화"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScoreChangeGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="누적된 기록이 쌓이면 건강점수 변화 추이를 확인할 수 있습니다."
                android:textColor="@color/LightBlack"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_summary_box"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:padding="16dp"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@color/MainGreen" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@color/MainGreen" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@color/MainGreen" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@color/MainGreen" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@color/MainGreen" />
            </LinearLayout>
        </LinearLayout>

        <!-- 최근 위험 요소 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최근 위험 요소"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthRisk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="현재 특별한 위험 요소가 없습니다."
                android:textColor="@color/MainGreen"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- 식사별 기록 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="식사별 기록"
            android:textColor="@color/GoodBlack"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBreakfastLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="아침  |  기록 없음"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvLunchLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="점심  |  기록 없음"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvDinnerLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="저녁  |  기록 없음"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <!-- 오늘의 건강 팁 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 건강 팁"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthLogTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="식품을 추가하면 오늘의 식단을 바탕으로 건강 팁을 확인할 수 있습니다."
                android:textColor="@color/LightBlack"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>