<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/health_point_log_title"
            android:textColor="@color/GoodBlack"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHealthLogDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/health_log_default_date"
            android:textColor="@color/LightBlack"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/today_health_score"
                android:textColor="@color/LightBlack"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvAverageHealthScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/zero_score"
                android:textColor="@color/MainGreen"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/health_summary_default"
                android:textColor="@color/GoodBlack"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/health_score_change"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScoreChangeGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/health_score_change_guide"
                android:textColor="@color/LightBlack"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_summary_box"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_risk_factor"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthRisk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/no_risk_factor"
                android:textColor="@color/MainGreen"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/meal_record"
            android:textColor="@color/GoodBlack"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBreakfastLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="@string/breakfast_no_record"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvLunchLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="@string/lunch_no_record"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvDinnerLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_category_chip"
            android:padding="16dp"
            android:text="@string/dinner_no_record"
            android:textColor="@color/GoodBlack"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_category_chip"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/today_health_tip"
                android:textColor="@color/GoodBlack"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHealthLogTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/health_tip_default"
                android:textColor="@color/LightBlack"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>