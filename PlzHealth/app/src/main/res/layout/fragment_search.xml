<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="16dp">

    <!-- 검색창 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/ivSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/outline_search_24"
            app:tint="@color/LightGray"
            android:contentDescription="@string/searchDescription"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/searchHint"
            android:background="@null"
            android:paddingStart="8dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"
            android:autofillHints="none"/>
    </LinearLayout>

    <!-- 현재 단계 표시 -->
    <TextView
        android:id="@+id/tvCategoryStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="대분류 선택"
        android:textSize="13sp"
        android:textColor="@color/LightGray"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"/>

    <!-- 뒤로가기 버튼 -->
    <TextView
        android:id="@+id/tvBackCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← 이전"
        android:textSize="13sp"
        android:textColor="@color/GoodBlack"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:padding="4dp"/>

    <!-- 카테고리 그리드 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 식품 결과 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFoodResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>