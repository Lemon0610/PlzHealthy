<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_item_food"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="12dp">
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_score_circle"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvFoodScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/number"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Score"
                android:textSize="11sp"
                android:textColor="#4CAF50"/>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tvPopupFoodName"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"/>
        <TextView
            android:id="@+id/tvRecommendReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tvRecommendReason"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvScoreDiff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tvScoreDiff"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:background="@drawable/bg_summary_box"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:layout_marginStart="8dp"/>
</LinearLayout>