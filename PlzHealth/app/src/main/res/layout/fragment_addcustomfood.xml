<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/foodAdd"
            android:textColor="@color/GoodBlack"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFoodName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:hint="@string/foodName"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:inputType="text"
            android:autofillHints="none"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/foodCate"
            android:textStyle="bold"
            android:textColor="@color/GoodBlack"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <Spinner
                android:id="@+id/spinnerMajor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.Spinner"
                android:spinnerMode="dropdown"/>

            <Spinner
                android:id="@+id/spinnerMiddle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                style="@style/Widget.AppCompat.Spinner"
                android:spinnerMode="dropdown"/>

            <Spinner
                android:id="@+id/spinnerMinor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                style="@style/Widget.AppCompat.Spinner"
                android:spinnerMode="dropdown"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etKcal"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/Kcal"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <EditText
            android:id="@+id/etProtein"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/danger"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <EditText
            android:id="@+id/etSugar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/etSugar"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <EditText
            android:id="@+id/etFiber"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/etFiber"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <EditText
            android:id="@+id/etSodium"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/etSodium"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <EditText
            android:id="@+id/etSaturatedFat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/etSaturatedFat"
            android:inputType="numberDecimal"
            android:textColor="@color/GoodBlack"
            android:textColorHint="@color/LightBlack"
            android:textSize="16sp"
            android:autofillHints="none"/>

        <Spinner
            android:id="@+id/spinnerMealType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnAddFood"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/MainGreen"
            android:text="@string/addToMeal"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>